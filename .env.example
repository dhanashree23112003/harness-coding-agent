# Required
GROQ_API_KEY=your-key-here
DATABASE_URL=postgresql://agent:agent@localhost:5432/agent_tools

# Model selection (default: llama-3.1-8b-instant)
AGENT_MODEL=llama-3.1-8b-instant

# Context compaction: fire when token estimate exceeds this value (default: 800)
CONTEXT_COMPACT_THRESHOLD=800

# Retry: max attempts and base delay in seconds for transient errors (default: 3, 1.0)
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0

# Rate limiting: outbound calls per minute and burst size (default: 30, 5)
RATE_LIMIT_RPM=30
RATE_LIMIT_BURST=5

# Optional: LangSmith tracing (https://smith.langchain.com)
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=your-langsmith-key
# LANGCHAIN_PROJECT=harness-coding-agent
